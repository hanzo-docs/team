    "@types/node": "^24.10.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
